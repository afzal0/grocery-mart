<?xml version="1.0" encoding="UTF-8"?>
<!-- Observability spine (NFR-OBS-01): structured console logs with the per-request
     correlation id (traceId) from CorrelationIdFilter. Swap the encoder for JSON
     (logstash/ECS) when shipping to a log aggregator in the hardening phase. -->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{traceId:-no-trace}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.grocerymart" level="DEBUG"/>
</configuration>
