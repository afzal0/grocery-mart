# Copy to .env and fill in. NEVER commit real secrets.

# --- Database ---
POSTGRES_DB=grocery_mart
POSTGRES_USER=grocery
POSTGRES_PASSWORD=grocery
DB_URL=jdbc:postgresql://localhost:5433/grocery_mart

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- S3 / MinIO (local) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=grocery-mart-media

# --- Auth ---
JWT_SECRET=change-me-dev-only-not-for-production

# --- Stripe (test) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Twilio (OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
